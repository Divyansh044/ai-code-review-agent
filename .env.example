# GitHub personal access token with repo + pull-request scopes,
# used to fetch PR diffs and post review comments.
GITHUB_TOKEN=

# Secret configured on the GitHub webhook, used to verify that
# incoming webhook requests actually came from GitHub.
GITHUB_WEBHOOK_SECRET=

# OpenAI API key used for LLM-based review generation.
OPENAI_API_KEY=

# OpenAI model used for review generation.
OPENAI_MODEL=gpt-4o-mini

# Python logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
